{
  "name": "clatter-code",
  "version": "1.0.0",
  "description": "An open-source CLI coding assistant built with Node.js and Rust.",
  "main": "src/index.js",
  "bin": {
    "clatter": "bin/clatter.js"
  },
  "type": "module",
  "scripts": {
    "start": "node bin/clatter.js",
    "build:rust": "cd rust-engine && cargo build --release",
    "install:local": "npm install && npm run build:rust"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "chalk": "^5.3.0",
    "chalk-animation": "^2.0.3",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "execa": "^8.0.1",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.12",
    "ora": "^7.0.1"
  }
}
